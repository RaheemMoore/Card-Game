# Copy this to .env and fill in your keys.
#
# CLIENT (VITE_*) — safe to bundle into the browser build.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here

# SERVER — for Vercel Functions under /api. NEVER prefix with VITE_ and
# never commit real values. As of Phase 0 the Anthropic Messages key is
# server-only; the browser calls /api/anthropic-messages instead. Same
# for Leonardo generation via /api/leonardo.
ANTHROPIC_API_KEY=sk-ant-server-only-key
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-server-only-key
LEONARDO_API_KEY=leonardo-server-only-key
# service_role bypasses RLS so server endpoints can insert into
# api_usage_events. Keep in Vercel env only — never in a client build.
SUPABASE_SERVICE_ROLE_KEY=sb-service-role-key-here
