# Copy this to .env and fill in your keys
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
VITE_LEONARDO_API_KEY=your-leonardo-api-key-here

# Supabase persistence (Phase 2). When both are set, the app boots against
# Supabase; when unset, it falls back to the legacy localStorage-only path
# for local dev without a project.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here
